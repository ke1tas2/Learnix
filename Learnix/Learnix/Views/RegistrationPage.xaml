<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Learnix.RegistrationPage"
             Title="Регистрация">

    <ScrollView BackgroundColor="#D6F0FA">
        <Grid Padding="30"
              RowDefinitions="Auto,Auto,*,Auto"
              RowSpacing="20"
              VerticalOptions="FillAndExpand"
              HorizontalOptions="FillAndExpand">

            <Image Source="logo.png"
                   Grid.Row="0"
                   HeightRequest="70"
                   VerticalOptions="Start"
                   HorizontalOptions="Center"/>

            <Label Grid.Row="1"
                   Text="Регистрация"
                   FontFamily="GameFontRegular"
                   FontSize="40"
                   VerticalOptions="End"
                   HorizontalOptions="Center"
                   TextColor="#3AAAE0"
                   Margin="0,40,0,0"/>

            <VerticalStackLayout Grid.Row="2"
                                 Spacing="15"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Start"
                                 Margin="0,60,0,0">

                <Entry x:Name="NameEntry"
                       FontFamily="GameFontRegular"
                       Placeholder="Введите имя или ФИО"
                       PlaceholderColor="Black"
                       BackgroundColor="Transparent"
                       TextColor="Black"
                       WidthRequest="280"
                       HeightRequest="45"
                       FontSize="20"/>

                <Entry x:Name="EmailEntry"
                       FontFamily="GameFontRegular"
                       Placeholder="Введите Email"
                       Keyboard="Email"
                       PlaceholderColor="Black"
                       BackgroundColor="Transparent"
                       TextColor="Black"
                       WidthRequest="280"
                       HeightRequest="45"
                       FontSize="20"/>

                <Entry x:Name="PasswordEntry"
                       FontFamily="GameFontRegular"
                       Placeholder="Введите пароль"
                       IsPassword="True"
                       PlaceholderColor="Black"
                       BackgroundColor="Transparent"
                       TextColor="Black"
                       WidthRequest="280"
                       HeightRequest="45"
                       FontSize="20"/>

                <Label Text="Минимум 6 символов"
                       FontSize="13"
                       TextColor="DimGray"
                       HorizontalOptions="Start"
                       Margin="4,-8,0,0"/>

                <VerticalStackLayout Spacing="8" WidthRequest="280">
                    <Label Text="Выберите класс"
                           FontFamily="GameFontRegular"
                           FontSize="18"
                           TextColor="Black"/>
                    <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="6">
                        <Button x:Name="Grade7Button" Text="7" CommandParameter="7" Clicked="OnGradeClicked"/>
                        <Button x:Name="Grade8Button" Grid.Column="1" Text="8" CommandParameter="8" Clicked="OnGradeClicked"/>
                        <Button x:Name="Grade9Button" Grid.Column="2" Text="9" CommandParameter="9" Clicked="OnGradeClicked"/>
                        <Button x:Name="Grade10Button" Grid.Column="3" Text="10" CommandParameter="10" Clicked="OnGradeClicked"/>
                        <Button x:Name="Grade11Button" Grid.Column="4" Text="11" CommandParameter="11" Clicked="OnGradeClicked"/>
                    </Grid>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="3"
                                 Spacing="10"
                                 HorizontalOptions="Center"
                                 VerticalOptions="End">

                <Button Text="Зарегистрироваться"
                        FontFamily="GameFontRegular"
                        x:Name="RegisterBtn"
                        FontSize="18"
                        BackgroundColor="#AFC9F8"
                        TextColor="Black"
                        CornerRadius="14"
                        WidthRequest="280"
                        HeightRequest="45"
                        Clicked="OnRegisterClicked"/>

                <Button Text="Уже есть аккаунт"
                        FontFamily="GameFontRegular"
                        FontSize="20"
                        BackgroundColor="Transparent"
                        TextColor="#3AAAE0"
                        Clicked="OnBackClicked"/>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
