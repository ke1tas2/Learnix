<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Learnix.Views.WhatSubject"
             Title="Предметы"
             BackgroundColor="#D6F0FA">

    <Grid RowDefinitions="Auto,*,Auto" Padding="24">
        <Label Grid.Row="0"
               Text="Что будем изучать?"
               FontFamily="GameFontRegular"
               TextColor="#3AAAE0"
               FontSize="32"
               HorizontalTextAlignment="Center"
               HorizontalOptions="Center"
               Margin="0,20,0,16"/>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="SubjectList"
                                 Spacing="12"
                                 HorizontalOptions="Center"/>
        </ScrollView>

        <Button Grid.Row="2"
                x:Name="ContinueBtn"
                Text="Начать обучение"
                FontFamily="GameFontRegular"
                FontSize="18"
                BackgroundColor="#AFC9F8"
                TextColor="Black"
                CornerRadius="10"
                WidthRequest="250"
                HeightRequest="45"
                HorizontalOptions="Center"
                Margin="0,16,0,0"
                Clicked="OnContinueClicked"/>
    </Grid>
</ContentPage>
