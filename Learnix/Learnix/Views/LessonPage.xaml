<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Learnix.Views.LessonPage"
             Title="Урок"
             BackgroundColor="#D6F0FA">
    <Grid RowDefinitions="Auto,*,Auto" Padding="20">
        <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,16,0,12">
            <Label x:Name="LevelTitleLabel"
                   Text="Урок"
                   FontFamily="GameFontRegular"
                   FontSize="28"
                   TextColor="#3AAAE0"/>
            <Label x:Name="LevelSubtitleLabel"
                   Text="Выберите правильные ответы"
                   FontSize="14"
                   TextColor="Black"/>
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="ExerciseStack" Spacing="14"/>
        </ScrollView>

        <Button Grid.Row="2"
                x:Name="SubmitBtn"
                Text="Проверить"
                FontFamily="GameFontRegular"
                FontSize="18"
                BackgroundColor="#AFC9F8"
                TextColor="Black"
                CornerRadius="10"
                HeightRequest="45"
                Margin="0,16,0,0"
                Clicked="OnSubmitClicked"/>
    </Grid>
</ContentPage>
