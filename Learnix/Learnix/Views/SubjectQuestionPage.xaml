<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Learnix.Views.SubjectQuestionPage"
             Title="Learnix"
             BackgroundColor="#D6F0FA">
    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="20">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,16,0,10">
            <VerticalStackLayout Spacing="2">
                <Label x:Name="GreetingLabel"
                       Text="Learnix"
                       FontFamily="GameFontRegular"
                       FontSize="30"
                       TextColor="#3AAAE0"/>
                <Label x:Name="GoalLabel"
                       Text="Сегодняшняя цель"
                       FontSize="14"
                       TextColor="Black"/>
            </VerticalStackLayout>

            <Button Grid.Column="1"
                    Text="Профиль"
                    FontFamily="GameFontRegular"
                    FontSize="16"
                    BackgroundColor="#AFC9F8"
                    TextColor="Black"
                    CornerRadius="10"
                    Clicked="OnProfileClicked"/>
        </Grid>

        <Border Grid.Row="1"
                Stroke="#3AAAE0"
                StrokeThickness="2"
                StrokeShape="RoundRectangle 12"
                BackgroundColor="White"
                Padding="12"
                Margin="0,0,0,14">
            <Grid ColumnDefinitions="*,*,*">
                <VerticalStackLayout>
                    <Label Text="XP" FontSize="12" TextColor="DimGray"/>
                    <Label x:Name="XpLabel" FontSize="20" FontFamily="GameFontRegular" TextColor="Black"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1">
                    <Label Text="Серия" FontSize="12" TextColor="DimGray"/>
                    <Label x:Name="StreakLabel" FontSize="20" FontFamily="GameFontRegular" TextColor="Black"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2">
                    <Label Text="Точность" FontSize="12" TextColor="DimGray"/>
                    <Label x:Name="AccuracyLabel" FontSize="20" FontFamily="GameFontRegular" TextColor="Black"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="2">
            <VerticalStackLayout x:Name="LevelStack" Spacing="14"/>
        </ScrollView>

        <Button Grid.Row="3"
                Text="Изменить предметы"
                FontFamily="GameFontRegular"
                FontSize="18"
                BackgroundColor="Transparent"
                TextColor="#3AAAE0"
                Clicked="OnChangeSubjectsClicked"/>
    </Grid>
</ContentPage>
