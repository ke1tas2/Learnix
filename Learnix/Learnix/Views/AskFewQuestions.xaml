<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Learnix.Views.AskFewQuestions"
             Title="AskFewQuestions">
    <Grid RowDefinitions="*, Auto"
          BackgroundColor="#D6F0FA">

        <VerticalStackLayout
            Grid.Row="0"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Padding="20">

            <Label x:Name="AskLabel"
                   Text="Ответьте на пару вопросов и мы начнем работу!"
                   FontFamily="GameFontRegular"
                   FontSize="30"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   TextColor="#3AAAE0"
                   Margin="0,0,0,30"
                   Opacity="0"
                   TranslationY="40">



            </Label>
            <Button x:Name="ContinueBttn"
                Text="Продолжим"
                FontFamily="GameFontRegular"
                FontSize="18"
                BackgroundColor="#AFC9F8"
                TextColor="Black"
                CornerRadius="10"
                WidthRequest="150"
                HeightRequest="45"
                Clicked="NextBttnClicked"
                Opacity="0"
                TranslationY="40">

            </Button>




        </VerticalStackLayout>
          
    </Grid>
</ContentPage>