<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Learnix.Views.ProfilePage"
             Title="Профиль"
             BackgroundColor="#F7F7F7">
    <Grid RowDefinitions="Auto,*,Auto" Padding="20">
        <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,18,0,14">
            <Label x:Name="NameLabel"
                   Text="Профиль"
                   FontFamily="GameFontRegular"
                   FontSize="32"
                   TextColor="#58CC02"/>
            <Label x:Name="ClassLabel"
                   Text="Статистика обучения"
                   FontSize="15"
                   TextColor="Black"/>
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="ProfileStack" Spacing="14"/>
        </ScrollView>

        <VerticalStackLayout Grid.Row="2" Spacing="10" Margin="0,16,0,0">
            <Button x:Name="AdminBtn"
                    Text="Админ-панель"
                    FontFamily="GameFontRegular"
                    FontSize="18"
                    BackgroundColor="White"
                    BorderColor="#E5E5E5"
                    BorderWidth="2"
                    TextColor="Black"
                    CornerRadius="10"
                    HeightRequest="45"
                    IsVisible="False"
                    Clicked="OnAdminClicked"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Text="К уровням"
                        FontFamily="GameFontRegular"
                        FontSize="18"
                        BackgroundColor="#58CC02"
                        TextColor="White"
                        CornerRadius="14"
                        HeightRequest="45"
                        Clicked="OnBackClicked"/>

                <Button Grid.Column="1"
                        Text="Выйти"
                        FontFamily="GameFontRegular"
                        FontSize="18"
                        BackgroundColor="White"
                        BorderColor="#E5E5E5"
                        BorderWidth="2"
                        TextColor="Black"
                        CornerRadius="10"
                        HeightRequest="45"
                        Clicked="OnLogoutClicked"/>
            </Grid>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
